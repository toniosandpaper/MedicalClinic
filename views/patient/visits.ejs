<!DOCTYPE html>
<html>
<head>
    <title>Your Visits</title>
    <style>
        table { border-collapse: collapse; width: 50%; margin-top: 20px; }
        th, td { border: 1px solid #ccc; padding: 10px; text-align: left; }
        th { background-color: #f4f4f4; }
    </style>
</head>
<body>
    <h2>Visit History Report</h2>
    
    <table>
        <thead>
            <tr>
                <th>ID</th> 
                <th>Date</th>
                <th>Doctor</th> <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <% visits.forEach(visit => { %>
                <tr>
                    <td><%= visit.AppointmentID %></td> 
                    <td><%= new Date(visit.AppointmentDate).toLocaleDateString() %></td>
                    
                    <td>
                        Dr. <%= visit.FirstName %> <%= visit.LastName %>
                    </td>
                    
                    <td><strong><%= visit.Status %></strong></td>
                </tr>
            <% }); %>
        </tbody>
    </table>

    <br>
    <a href="/patient/profile">Back to Profile</a>
</body>
</html>