<!DOCTYPE html>
<html>
<head>
    <title>Book Appointment</title>
    <style>
        body { font-family: sans-serif; padding: 20px; }
        label { display: block; margin-top: 15px; font-weight: bold; }
        select, input { padding: 8px; width: 300px; margin-top: 5px; }
        button { margin-top: 20px; padding: 10px 20px; background-color: #2e4d2e; color: white; border: none; cursor: pointer; border-radius: 4px; }
        button:hover { background-color: #3d663d; }
    </style>
</head>
<body>
    <h2>Book a New Appointment</h2>
    
    <form action="/patient/book" method="POST">
        
        <label>Select Doctor:</label>
        <select name="doctorId" id="doctorID" required 
                oninvalid="this.setCustomValidity('Please select a Doctor.')" 
                oninput="this.setCustomValidity('')">
            <option value="" disabled selected>-- Choose a Doctor --</option>
            <% doctors.forEach(doc => { %>
                <option value="<%= doc.EmployeeID %>">
                    Dr. <%= doc.FirstName %> <%= doc.LastName %>
                </option>
            <% }) %>
        </select>

        <label>Date and Time:</label>
        <input type="datetime-local" name="date" required>

        <button type="submit">Confirm Booking</button>
    </form>

    <br>
    <a href="/patient/profile">Cancel and go back</a>
</body>
</html>