<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/styles.css" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />

    <title>Register</title>
  </head>
  <body class = "register-page">
    <div class="form-wrapper">
      <div class="form-container">
        <h1>Register Patient</h1>
        <p class="subtitle">Please fill out this form</p>

        <form action="/patient/register" method="POST">
          <div class="form-group">
            <label>Name</label>
            <div class="form-grid">
              <input name="FName" placeholder="First Name" required />
              <input name="MName" placeholder="Middle Name" />
              <input name="LName" placeholder="Last Name" required />
            </div>
          </div>

          <div class="form-group">
            <label>Date of Birth</label>
            <input type="date" name="Dob" required />
          </div>

          <div class="form-group">
            <label>Address</label>
            <input name="Address" required />
          </div>

          <div class="form-group">
            <label>Phone Number</label>
            <input name="PhoneNumber" placeholder="0000000000" minlength = "10" maxlength="10" />
          </div>

          <div class="form-group">
            <label>Email</label>
            <input type="email" name="Email" required />
          </div>

          <div class="form-group">
            <label>Password</label>
            <input type="password" name="Password" required />
          </div>

          <div class="form-group">
            <label>Gender</label>
            <select name="GenderCode" required>
              <option value="">Select Gender</option>
              <option value="1">Male</option>
              <option value="2">Female</option>
            </select>
          </div>

          <div class="form-group">
            <label>Race</label>
            <select name="RaceCode">
              <option value="">Select Race</option>
              <option value="1">White</option>
              <option value="2">African</option>
              <option value="3">Asian</option>
            </select>
          </div>

          <div class="form-group">
            <label>Ethnicity</label>
            <select name="EthnicityCode">
              <option value="">Select Ethnicity</option>
              <option value="1">Hispanic</option>
              <option value="2">Latin American</option>
              <option value="3">African</option>
              <option value="4">Caribbean</option>
              <option value="5">Indian</option>
              <option value="6">Melanesian</option>
              <option value="7">Chinese</option>
              <option value="8">Japanese</option>
              <option value="9">Korean</option>
              <option value="10">Arabic</option>
              <option value="11">European</option>
              <option value="12">Other</option>
            </select>
          </div>

          <div class="insurance-group">
            <label class="checkbox-label">
              <input type="checkbox" name="HasInsurance" />
              Has Insurance
            </label>
          </div>

          <button type="submit">Register</button>
        </form>
      </div>
    </div>
  </body>
</html>
