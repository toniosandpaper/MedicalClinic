        <option value="Admin">Admin</option>
        <option value="Doctor">Doctor</option>
        <option value="Nurse">Nurse</option>
        <option value="Receptionist">Receptionist</option>
    </select>&#9;
    Department:<input type="text" placeholder="Department" onChange={change} name="Department"/>
    <br>Address:<input type="text" placeholder="Address" onChange={change} name="Address"/>
    Phone Number:<input type="text" placeholder="000000000" onChange={change} name="PhoneNumber"/>
    <br>Email:<input type="text" placeholder="Email" onChange={change} name="Email"/>
    Password:<input type="text" placeholder="Password" onChange={change} name="Password"/>
