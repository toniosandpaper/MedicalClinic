<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Add New Employee</title>
    <style>
        body { font-family: sans-serif; margin: 40px; }
        table { border-collapse: collapse; width: 100%; margin-top: 20px; }
        th, td { border: 1px solid #ccc; padding: 12px; text-align: left; }
        th { background-color: #f4f4f4; }
        .form-section { background: #f9f9f9; padding: 20px; border-radius: 8px; }
        input, button { padding: 8px; margin: 5px; }
        button { background-color: #2e4d2e; color: white; border: none; cursor: pointer; }
    </style>
</head>
<body>

    <div class="form-section">
        <h1>Add New Employee</h1>
        <form action="/admin/addemp" method="post">
            <label>First Name:
                <input type="text" name="FirstName" maxlength="30"/>
            </label>
            <label>Last Name:
                <input type="text" name="LastName" maxlength="30"/>
            </label>
            <label>Birth Date:
                <input type="date" name="Birthdate"/>
            </label><br><br>
            <label>Gender:
                <select name="GenderCode">
                    <option value="">Select Gender</option>
                    <option value="1">Male</option>
                    <option value="2">Female</option>
                    <option value="3">Other</option>
                </select>
            </label>
            <label>Race:
                <select name="RaceCode">
                    <option value="">Select Race</option>
                    <option value="1">White</option>
                    <option value="3">African</option>
                    <option value="2">Asian</option>
                    <option value="5">Other</option>
                </select>
            </label>
            <label>Ethnicity:
                <select name="EthnicityCode">
                    <option value="">Select Ethnicity</option>
                    <option value="1">Hispanic</option>
                    <option value="2">Latin American</option>
                    <option value="3">African</option>
                    <option value="4">Caribbean</option>
                    <option value="5">Indian</option>
                    <option value="6">Melanesian</option>
                    <option value="7">Chinese</option>
                    <option value="8">Japanese</option>
                    <option value="9">Korean</option>
                    <option value="10">Arabic</option>
                    <option value="11">European</option>
                    <option value="12">Other</option>
                </select>
            </label><br><br>
            <label>Role:
                <select name="RaceCode">
                    <option value="">Select Race</option>
                    <option value="1">White</option>
                    <option value="3">African</option>
                    <option value="2">Asian</option>
                    <option value="5">Other</option>
                </select>
            </label>
            <label>Department:
                <select name="DepartmentID">
                    <option value="">Select Department</option>
                    <option value="1">General</option>
                    <option value="2">Optometry</option>
                    <option value="3">Cardiology</option>
                    <option value="4">Orthopedics</option>
                </select>
            </label><br>
            <label>Address:
                <input type="text" name="Address" maxlength="100"/>
            </label>
            <label>Phone Number:
                <input type="tel" placeholder="000000000" name="PhoneNumber" minlength="10" maxlength="10"/>
            </label><br>
            <label>Email:
                <input type="email" placeholder="Email" name="Email"/>
            </label>
            <label>Password:
                <input type="text" placeholder="Password" name="Password"/>
            </label>
            <br><br>If A Doctor:<br>
            <label>Specialty:
                <input type="text" placeholder="Specialty" name="Specialty" maxlength="20"/>
            </label>
            <label>Is A Primary Care Physician:
                <select name="IsPrimaryCare">
                    <option value="">Select</option>
                    <option value="1">Yes</option>
                    <option value="0">No</option>
                </select>
            </label>
            <br><br>If A Nurse:<br>
            <label>Assigned Doctor ID:
                <input type="text" placeholder="0000" name="AssignedDoctorID"/>
            </label><br>
            <button type="submit">Create Employee</button>
        </form>
</body>
</html>
