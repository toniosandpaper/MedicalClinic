<!-- General Appointment Report
 
SELECT D.DepartmentName,O.OfficeName,COUNT(A.AppointmentID) AS "Appointments" 
FROM department AS D,appointment AS A,office AS O
WHERE A.officeID=O.officeID AND D.OfficeID=O.OfficeID AND A.AppointmentDate >= min AND A.AppointmentDate <= max
GROUP BY D.DepartmentName
ORDER BY Appointments DESC;

-->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>General Appointment Report</title>
    <style>
        body { font-family: sans-serif; margin: 40px; }
        table { border-collapse: collapse; width: 100%; margin-top: 20px; }
        th, td { border: 1px solid #ccc; padding: 12px; text-align: left; }
        th { background-color: #f4f4f4; }
        .form-section { background: #f9f9f9; padding: 20px; border-radius: 8px; }
        input, button { padding: 8px; margin: 5px; }
        button { background-color: #2e4d2e; color: white; border: none; cursor: pointer; }
    </style>
</head>
<body>

    <div class="form-section">
        <h1>General Appointment Report</h1>
        <p>Insert Minimum and Maximum Range for the Dates</p>
        
        <form action="/admin/pullgar" method="post">
            <label>Minimum: 
                <input type="date" name="min" required>
            </label>
            <label>Maximum: 
                <input type="date" name="max" required>
            </label>
            <button type="submit">Generate Report</button>
        </form>
        <hr>
        <% if (locals.results && results.length > 0) { %>
            <h2>Report Results</h2>
            <table border="1" cellpadding="10" style="border-collapse: collapse; width: 100%;">
                <thead>
                    <tr style="background-color: #f2f2f2;">
                        <th>Department</th>
                        <th>Office</th>
                        <th>Total Appointments</th>
                    </tr>
                </thead>
                <tbody>
                    <% results.forEach(row => { %>
                        <tr>
                            <td><%= row.DepartmentName %></td>
                            <td><%= row.OfficeName %></td>
                            <td><%= row.Appointments %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else if (locals.results) { %>
            <p>No appointments found for those dates.</p>
        <% } %>
    </div>
    <hr>
    <% if (locals.results && results.length > 0) { %>
        <h2>Report Results</h2>
        <table>
            <thead>
                <tr>
                    <th>Department</th>
                    <th>Office</th>
                    <th>Total Appointments</th>
                </tr>
            </thead>
            <tbody>
                <% results.forEach(row => { %>
                    <tr>
                        <td><%= row.DepartmentName %></td>
                        <td><%= row.OfficeName %></td>
                        <td><%= row.Appointments %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } else if (locals.results) { %>
        <p><strong>No data found</strong> for those specific dates.</p>
    <% } %>
</body>
</html>